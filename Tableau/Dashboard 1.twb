      <column caption='Revenue ' datatype='real' name='[Calculation_0246298174152705]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value])' />
      </column>
      <column caption='No . of Orders' datatype='integer' name='[Calculation_0246298174668802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([order_id])' />
      </column>
      <column caption='No. Of Customers' datatype='integer' name='[Calculation_0246298175127555]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_unique_id])' />
      </column>
      <column caption='Avg Order Value' datatype='real' name='[Calculation_0246298234257413]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value])/COUNTD([order_id])' />
      </column>
      <column caption='MOM Growth %' datatype='real' name='[Calculation_0246298234687494]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([payment_value]) - LOOKUP(SUM([payment_value]),-1))/ ABS(LOOKUP(SUM([payment_value]),-1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Delivery Days' datatype='integer' name='[Calculation_0246298235961351]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[order_purchase_timestamp],[order_delivered_customer_date])' />
      </column>
      <column caption='Customer Type' datatype='string' name='[Calculation_0405177986822144]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([federated.0wp9qdw12avsa910q3oo91izu14u].[frequency]) &gt; 1 &#13;&#10;THEN &quot;Repeat Customer&quot; &#13;&#10;ELSE &quot;One-Time Customer&quot; &#13;&#10;END' />
      </column>
      <column caption='Order Purchase time period' datatype='boolean' name='[Calculation_0517053813657600]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[order_purchase_timestamp] &gt;= [Parameters].[Parameter 1] AND [order_purchase_timestamp] &lt;=[Parameters].[Start Date (copy)]' />
      </column>
      <column caption='Dilivery Days' datatype='integer' name='[Calculation_0813922671882240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order_purchase_timestamp], [order_delivered_customer_date])' />
